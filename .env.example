# GitHub App credentials for docs feedback → GitHub Discussions
# See src/lib/github.ts — installation ID is auto-discovered from the repo/owner

# App ID from https://github.com/settings/apps/<app-name>
GITHUB_APP_ID=

# Contents of the private key .pem file, with newlines escaped as \n
# Example: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY=

# Supabase (이메일 구독)
# Project URL: https://<project>.supabase.co
SUPABASE_URL=

# Secret key (sb_secret_...). 서버 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것.
SUPABASE_SECRET_KEY=
