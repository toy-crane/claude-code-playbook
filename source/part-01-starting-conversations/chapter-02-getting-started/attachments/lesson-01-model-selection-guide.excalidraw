    {
      "type": "text",
      "id": "sonnet_tasks",
      "x": 320,
      "y": 210,
      "width": 190,
      "height": 100,
      "text": "일반적인 기능 구현\n코드 리뷰\n테스트 작성\n대부분의 일상 개발 작업",
      "originalText": "일반적인 기능 구현\n코드 리뷰\n테스트 작성\n대부분의 일상 개발 작업",
      "fontSize": 14,
      "fontFamily": 6,
